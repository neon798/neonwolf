# Neonwolf neonwolf-prefs.patch
#
# Author:        Malte Jürgens <maltejur@dismail.de>
# Description:   Add custom Neonwolf pref defaults
# Last Updated:  2023-10-30
# License:       MPL 2.0
#
# The purpose of this patch is to show the defaults of our custom prefs
# in `about:config`, making it easier to change them.
--- a/browser/app/profile/firefox.js
+++ b/browser/app/profile/firefox.js
@@ -21,0 +21,5 @@
+
+pref("neonwolf.uBO.assetsBootstrapLocation", "");
+pref("neonwolf.aboutMenu.checkVersion", false);
+pref("neonwolf.hidePasswdmgr", false);
+pref("neonwolf.debugger.force_detach", false);
+pref("neonwolf.console.logging_disabled", false);
+
