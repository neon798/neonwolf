+NS_IMETHODIMP ContentClassifierService::GetCosmeticHideSelectors(
+    const nsACString& aUrl, nsTArray<nsCString>& aRetVal) {
+  aRetVal.Clear();
+
+  MutexAutoLock lock(mLock);
+  if (mInitPhase != InitPhase::InitSucceeded) {
+    return NS_OK;
+  }
+
+  nsTHashSet<nsCString> seen;
+  for (const auto& engine : mBlockEngines) {
+    nsTArray<nsCString> selectors;
+    if (NS_FAILED(engine->GetCosmeticHideSelectors(aUrl, selectors))) {
+      continue;
+    }
+    for (auto& selector : selectors) {
+      if (seen.EnsureInserted(selector)) {
+        aRetVal.AppendElement(selector);
+      }
+    }
+  }
+
+  MOZ_LOG_FMT(gContentClassifierLog, LogLevel::Debug,
+              "GetCosmeticHideSelectors - url={} count={}", aUrl,
+              aRetVal.Length());
+  return NS_OK;
+}
