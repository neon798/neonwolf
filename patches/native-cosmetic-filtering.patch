+"use strict";
+
+const COSMETIC_LIST_URL =
+  "https://example.net/" + TEST_PATH + "cosmetic_list.txt";
+const COSMETIC_PAGE = TEST_DOMAIN + TEST_PATH + "cosmetic_page.html";
+
+const COSMETIC_PREFS = {
+  set: [
+    ["privacy.trackingprotection.content.testing", true],
+    ["privacy.trackingprotection.content.protection.enabled", true],
+    [
+      "privacy.trackingprotection.content.protection.test_list_urls",
+      COSMETIC_LIST_URL,
+    ],
+    ["privacy.trackingprotection.content.annotation.enabled", false],
+    ["privacy.trackingprotection.content.annotation.test_list_urls", ""],
+  ],
+};
+
+// Validates the native chain: Rust FFI (url_cosmetic_resources) ->
+// ContentClassifierService selector aggregation -> scriptable IDL.
+add_task(async function test_cosmetic_selectors_via_service() {
+  let listsLoaded = TestUtils.topicObserved(LISTS_LOADED_TOPIC);
+  await SpecialPowers.pushPrefEnv(COSMETIC_PREFS);
+
+  let tab = await BrowserTestUtils.openNewForegroundTab(gBrowser, TEST_TOP_PAGE);
+  await listsLoaded;
+
+  let service = Cc["@mozilla.org/content-classifier-service;1"].getService(
+    Ci.nsIContentClassifierService
+  );
+  let selectors = service.getCosmeticHideSelectors("https://example.net/");
+  ok(
+    selectors.includes(".neonwolf-test-ad"),
+    "Service returns the domain-specific cosmetic selector, got: [" +
+      selectors.join(", ") +
+      "]"
+  );
+
+  BrowserTestUtils.removeTab(tab);
+});
+
+// Validates the JSActor end-to-end: CosmeticFilterChild queries the parent on
+// document creation and injects an agent sheet that hides the matched element.
+add_task(async function test_cosmetic_actor_hides_element() {
+  let listsLoaded = TestUtils.topicObserved(LISTS_LOADED_TOPIC);
+  await SpecialPowers.pushPrefEnv(COSMETIC_PREFS);
+
+  let tab = await BrowserTestUtils.openNewForegroundTab(gBrowser, COSMETIC_PAGE);
+  let browser = tab.linkedBrowser;
+  await listsLoaded;
+
+  // Reload now that engines are built, so the actor queries a populated service.
+  BrowserTestUtils.startLoadingURIString(browser, COSMETIC_PAGE);
+  await BrowserTestUtils.browserLoaded(browser);
+
+  await SpecialPowers.spawn(browser, [], async () => {
+    await ContentTaskUtils.waitForCondition(() => {
+      let el = content.document.querySelector(".neonwolf-test-ad");
+      return el && content.getComputedStyle(el).display === "none";
+    }, "injected agent sheet should hide .neonwolf-test-ad");
+
+    let ad = content.document.querySelector(".neonwolf-test-ad");
+    Assert.equal(
+      content.getComputedStyle(ad).display,
+      "none",
+      "ad element is hidden by cosmetic filtering"
+    );
+
+    let real = content.document.querySelector(".content");
+    Assert.notEqual(
+      content.getComputedStyle(real).display,
+      "none",
+      "non-matching content is left visible"
+    );
+  });
+
+  BrowserTestUtils.removeTab(tab);
+});
