@@ -0,0 +1,22 @@
+/* This Source Code Form is subject to the terms of the Mozilla Public
+ * License, v. 2.0. If a copy of the MPL was not distributed with this
+ * file, You can obtain one at http://mozilla.org/MPL/2.0/. */
+
+// Neonwolf cosmetic filtering: parent-side bridge between content documents and
+// the native content-classifier service, which owns the adblock-rust engines.
+export class CosmeticFilterParent extends JSWindowActorParent {
+  receiveMessage(message) {
+    if (message.name !== "GetCosmeticHideSelectors") {
+      return [];
+    }
+
+    try {
+      const service = Cc[
+        "@mozilla.org/content-classifier-service;1"
+      ].getService(Ci.nsIContentClassifierService);
+      return service.getCosmeticHideSelectors(message.data.url);
+    } catch (e) {
+      return [];
+    }
+  }
+}
