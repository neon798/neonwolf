# Neonwolf: native cosmetic ad filtering on the bundled content-classifier
# (adblock-rust) engine.
#
# Exposes per-URL element-hiding selectors from the engine through a new
# scriptable service method and injects them into documents as an agent
# stylesheet via a JSWindowActor, hiding ad/tracker elements with no extension.
#
# Chain: Rust FFI (url_cosmetic_resources) -> ContentClassifierService selector
# aggregation/dedup -> nsIContentClassifierService.getCosmeticHideSelectors ->
# @mozilla.org/content-classifier-service;1 -> CosmeticFilter parent/child actor
# -> windowUtils.loadSheetUsingURIString(AGENT_SHEET).
#
# Depends on the content-classifier blocking infra (see rs-blocker.patch) being
# present; lists must be loaded for selectors to be produced.
diff -ruN a/toolkit/actors/CosmeticFilterChild.sys.mjs b/toolkit/actors/CosmeticFilterChild.sys.mjs
--- a/toolkit/actors/CosmeticFilterChild.sys.mjs
+++ b/toolkit/actors/CosmeticFilterChild.sys.mjs
@@ -0,0 +1,43 @@
+/* This Source Code Form is subject to the terms of the Mozilla Public
+ * License, v. 2.0. If a copy of the MPL was not distributed with this
+ * file, You can obtain one at http://mozilla.org/MPL/2.0/. */
+
+// Neonwolf cosmetic filtering: on document creation, ask the parent for the
+// element-hiding selectors that apply to this document's URL and inject them
+// as an agent stylesheet so ad/tracker elements are hidden before paint.
+export class CosmeticFilterChild extends JSWindowActorChild {
+  async handleEvent(event) {
+    if (event.type !== "DOMDocElementInserted") {
+      return;
+    }
+
+    const window = this.contentWindow;
+    const uri = this.document?.documentURIObject;
+    if (!window || !uri || !(uri.schemeIs("http") || uri.schemeIs("https"))) {
+      return;
+    }
+
+    let selectors;
+    try {
+      selectors = await this.sendQuery("GetCosmeticHideSelectors", {
+        url: uri.spec,
+      });
+    } catch (e) {
+      return;
+    }
+
+    if (!selectors?.length || Cu.isDeadWrapper(window)) {
+      return;
+    }
+
+    const css =
+      "data:text/css," +
+      encodeURIComponent(selectors.join(",\n") + "{display:none!important}");
+    try {
+      window.windowUtils.loadSheetUsingURIString(
+        css,
+        window.windowUtils.AGENT_SHEET
+      );
+    } catch (e) {}
+  }
+}
diff -ruN a/toolkit/actors/CosmeticFilterParent.sys.mjs b/toolkit/actors/CosmeticFilterParent.sys.mjs
