+// Neonwolf M3: per-site Shields-down skips native content-classifier blocking.
+// Returns true when the user has put the top-level page for this channel into
+// "shields down" state, i.e. a "neonwolf-shields" permission == ALLOW on the
+// top-level document's content principal (set by the Shields panel). Shields is
+// a single per-top-level-site switch (like Brave/uBO), so we key off the
+// top-level document's principal, NOT each subresource's origin.
+bool NeonwolfShieldsDownForChannel(nsIChannel* aChannel) {
+  MOZ_ASSERT(NS_IsMainThread());
+  MOZ_ASSERT(XRE_IsParentProcess());
+
+  nsCOMPtr<nsILoadInfo> loadInfo = aChannel->LoadInfo();
+  if (!loadInfo) {
+    return false;
+  }
+
+  // Resolve the top-level document's principal via the target browsing
+  // context's top window global. This mirrors how
+  // UrlClassifierCommon::GetTopWindowURI walks to the top WindowGlobalParent,
+  // but uses its DocumentPrincipal (which carries the correct origin
+  // attributes, e.g. private browsing / containers) so the permission lookup
+  // matches the principal the Shields panel stored the permission on.
+  RefPtr<dom::BrowsingContext> browsingContext;
+  if (NS_FAILED(loadInfo->GetTargetBrowsingContext(
+          getter_AddRefs(browsingContext))) ||
+      !browsingContext) {
+    return false;
+  }
+
+  dom::CanonicalBrowsingContext* top = browsingContext->Canonical()->Top();
+  dom::WindowGlobalParent* wgp = top->GetCurrentWindowGlobal();
+  if (!wgp) {
+    return false;
+  }
+
+  nsCOMPtr<nsIPrincipal> topPrincipal = wgp->DocumentPrincipal();
+  if (!topPrincipal) {
+    return false;
+  }
+
+  nsCOMPtr<nsIPermissionManager> permMgr =
+      components::PermissionManager::Service();
+  if (!permMgr) {
+    return false;
+  }
+
+  uint32_t perm = nsIPermissionManager::UNKNOWN_ACTION;
+  if (NS_FAILED(permMgr->TestPermissionFromPrincipal(
+          topPrincipal, "neonwolf-shields"_ns, &perm))) {
+    return false;
+  }
+
+  return perm == nsIPermissionManager::ALLOW_ACTION;
+}
+
 }  // namespace
 
