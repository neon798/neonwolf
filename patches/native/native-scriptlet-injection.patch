+void ContentClassifierService::EnsureResourceBundleLoaded() {
+  mLock.AssertCurrentThreadOwns();
+
+  if (mResourceBundleLoaded) {
+    return;
+  }
+  // Mark as attempted regardless of outcome: a missing/unreadable bundle is a
+  // permanent (for this session) graceful-degradation state, not retried.
+  mResourceBundleLoaded = true;
+
+  nsCOMPtr<nsIFile> file;
+  nsresult rv = NS_GetSpecialDirectory(NS_GRE_DIR, getter_AddRefs(file));
+  if (NS_FAILED(rv) || !file) {
+    return;
+  }
+  // App-specific defaults live under <GreD>/browser/defaults/settings/ (the
+  // lists dump lands at browser/defaults/settings/main/), so the bundle that
+  // FINAL_TARGET_FILES.defaults.settings packages is under browser/ too.
+  file->AppendNative("browser"_ns);
+  file->AppendNative("defaults"_ns);
+  file->AppendNative("settings"_ns);
+  file->AppendNative("ubo-resources.json"_ns);
+
+  bool exists = false;
+  if (NS_FAILED(file->Exists(&exists)) || !exists) {
+    MOZ_LOG(gContentClassifierLog, LogLevel::Debug,
+            ("EnsureResourceBundleLoaded - bundle absent; scriptlet injection "
+             "disabled"));
+    return;
+  }
+
+  int64_t size = 0;
+  if (NS_FAILED(file->GetFileSize(&size)) || size <= 0) {
+    return;
+  }
+
+  nsCOMPtr<nsIInputStream> stream;
+  rv = NS_NewLocalFileInputStream(getter_AddRefs(stream), file);
+  if (NS_FAILED(rv) || !stream) {
+    return;
+  }
+
+  nsAutoCString contents;
+  rv = NS_ReadInputStreamToString(stream, contents, static_cast<int64_t>(size));
+  if (NS_FAILED(rv)) {
+    return;
+  }
+
+  mResourceBundle = contents;
+  MOZ_LOG_FMT(gContentClassifierLog, LogLevel::Info,
+              "EnsureResourceBundleLoaded - loaded resource bundle ({} bytes)",
+              mResourceBundle.Length());
+}
+
+void ContentClassifierService::ApplyResourceBundle(
+    ContentClassifierEngine* aEngine) {
+  mLock.AssertCurrentThreadOwns();
+
+  EnsureResourceBundleLoaded();
+  if (mResourceBundle.IsEmpty()) {
+    return;
+  }
+  nsresult rv = aEngine->UseResources(mResourceBundle);
+  if (NS_FAILED(rv)) {
+    MOZ_LOG_FMT(gContentClassifierLog, LogLevel::Warning,
+                "ApplyResourceBundle - UseResources failed: {:#x}",
+                static_cast<uint32_t>(rv));
+  }
+}
