+// Neonwolf scriptlet injection: load the scriptlet/redirect resource bundle (a
+// JSON array of adblock Resource objects) into the engine. Without this, the
+// engine's assembled injected_script is always empty. Takes a *mut handle
+// because Engine::use_resources requires &mut self.
+#[no_mangle]
+pub unsafe extern "C" fn content_classifier_engine_use_resources(
+    engine: *mut ContentClassifierFFIEngine,
+    resources_json: &nsACString,
+) -> nsresult {
+    if engine.is_null() {
+        return NS_ERROR_INVALID_ARG;
+    }
+    let json_str = String::from_utf8_lossy(resources_json.as_ref()).to_string();
+    let resources: Vec<Resource> = match serde_json::from_str(&json_str) {
+        Ok(r) => r,
+        Err(_) => return NS_ERROR_FAILURE,
+    };
+    (&mut (*engine).engine).use_resources(resources);
+    NS_OK
+}
+
+// Neonwolf scriptlet injection: return the assembled scriptlet JS that applies
+// to aUrl. Empty if no scriptlets match or no resources were loaded.
+#[no_mangle]
+pub unsafe extern "C" fn content_classifier_engine_injected_script(
+    engine: *const ContentClassifierFFIEngine,
+    url: &nsACString,
+    out: &mut nsCString,
+) -> nsresult {
+    if engine.is_null() {
+        return NS_ERROR_INVALID_ARG;
+    }
+    let engine = &(*engine).engine;
+    let url_str = String::from_utf8_lossy(url.as_ref()).to_string();
+    let r = engine.url_cosmetic_resources(&url_str);
+    out.assign(&r.injected_script);
+    NS_OK
+}
