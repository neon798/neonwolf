+NS_IMETHODIMP ContentClassifierService::GetInjectedScript(
+    const nsACString& aUrl, nsACString& aRetVal) {
+  aRetVal.Truncate();
+
+  MutexAutoLock lock(mLock);
+  if (mInitPhase != InitPhase::InitSucceeded) {
+    return NS_OK;
+  }
+
+  for (const auto& engine : mBlockEngines) {
+    nsCString script;
+    if (NS_FAILED(engine->GetInjectedScript(aUrl, script)) ||
+        script.IsEmpty()) {
+      continue;
+    }
+    if (!aRetVal.IsEmpty()) {
+      aRetVal.Append('\n');
+    }
+    aRetVal.Append(script);
+  }
+
+  MOZ_LOG_FMT(gContentClassifierLog, LogLevel::Debug,
+              "GetInjectedScript - url={} length={}", aUrl, aRetVal.Length());
+  return NS_OK;
+}
