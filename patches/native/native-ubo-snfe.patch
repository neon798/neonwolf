diff -ruN a/toolkit/components/content-classifier/UBONetFilter.sys.mjs b/toolkit/components/content-classifier/UBONetFilter.sys.mjs
--- a/toolkit/components/content-classifier/UBONetFilter.sys.mjs	1969-12-31 17:00:00.000000000 -0700
+++ b/toolkit/components/content-classifier/UBONetFilter.sys.mjs	2026-07-01 20:31:20.638795139 -0600
@@ -0,0 +1,615 @@
+/* This Source Code Form is subject to the terms of the Mozilla Public
+ * License, v. 2.0. If a copy of the MPL was not distributed with this
+ * file, You can obtain one at http://mozilla.org/MPL/2.0/. */
+
+// Neonwolf native network filtering, powered by uBlock. Runs uBlock Origin's
+// actual StaticNetFilteringEngine (vendored in UBOSnfe.sys.mjs) in the parent
+// process and cancels matching http(s) subresource channels from an
+// http-on-opening-request observer. This is browser code, not an extension:
+// there is no extension flag, no web-accessible resources, and no
+// content-script signature for sites to fingerprint.
+//
+// Filter lists come from the same RemoteSettings collection the C++
+// ContentClassifierService consumes. The compiled engine is cached as a uBO
+// selfie in the profile, keyed on the record set, so warm startups skip the
+// full list compile.
+
+const lazy = {};
+
+ChromeUtils.defineESModuleGetters(lazy, {
+  RemoteSettings: "resource://services-settings/remote-settings.sys.mjs",
+  setTimeout: "resource://gre/modules/Timer.sys.mjs",
+  clearTimeout: "resource://gre/modules/Timer.sys.mjs",
+});
+
+ChromeUtils.defineLazyGetter(lazy, "log", () => {
+  return console.createInstance({
+    maxLogLevelPref: "privacy.trackingprotection.ubo.loglevel",
+    prefix: "UBONetFilter",
+  });
+});
+
+// uBO's neutered $redirect resources (vendored; see
+// scripts/vendor-ubo/build-redirect-resources.sh). Default export, so
+// defineESModuleGetters does not fit.
+ChromeUtils.defineLazyGetter(lazy, "redirectResources", () => {
+  return ChromeUtils.importESModule(
+    "resource://gre/modules/UBORedirectResources.sys.mjs"
+  ).default;
+});
+
+const COLLECTION_NAME = "content-classifier-lists";
+const ENABLED_PREF = "privacy.trackingprotection.ubo.network.enabled";
+const SELFIE_FILE = "ubo-snfe-selfie.json";
+// User custom filters, edited via the Neonwolf Custom Filters page and
+// compiled into the engine as an extra list. Changing it rebuilds the engine
+// and invalidates the selfie (its hash is folded into the selfie stamp).
+const USER_FILTERS_PREF = "privacy.trackingprotection.ubo.userFilters";
+const USER_FILTERS_LIST_NAME = "neonwolf-user-filters";
+const REBUILD_DEBOUNCE_MS = 400;
+
+const BLOCK = 1;
+
+ChromeUtils.defineLazyGetter(lazy, "typeMap", () => {
+  const cp = Ci.nsIContentPolicy;
+  return new Map([
+    [cp.TYPE_DOCUMENT, "main_frame"],
+    [cp.TYPE_SUBDOCUMENT, "sub_frame"],
+    [cp.TYPE_STYLESHEET, "stylesheet"],
+    [cp.TYPE_SCRIPT, "script"],
+    [cp.TYPE_IMAGE, "image"],
+    [cp.TYPE_IMAGESET, "image"],
+    [cp.TYPE_OBJECT, "object"],
+    [cp.TYPE_PING, "ping"],
+    [cp.TYPE_BEACON, "ping"],
+    [cp.TYPE_XMLHTTPREQUEST, "xmlhttprequest"],
+    [cp.TYPE_FETCH, "xmlhttprequest"],
+    [cp.TYPE_FONT, "font"],
+    [cp.TYPE_MEDIA, "media"],
+    [cp.TYPE_WEBSOCKET, "websocket"],
+  ]);
+});
+
+export const UBONetFilter = {
+  _snfe: null,
+  _initPromise: null,
+  _observing: false,
+  _prefObserving: false,
+  _rebuildQueue: null,
+  _rebuildTimer: null,
+  // Per-source-site block counts, keyed like the C++ service's counter: the
+  // loading principal's base domain. Read by the Neonwolf Shields panel.
+  _blockedCounts: new Map(),
+  // Recently hard-cancelled request URLs (NOT redirected ones, which load a
+  // shim and never error). The cosmetic child actor queries these to collapse
+  // leftover broken placeholders. Insertion-ordered Set, FIFO-evicted at cap;
+  // a single global set (not per-tab) is enough because a URL present here was
+  // genuinely blocked and would block in any tab that loads it.
+  _recentBlocked: new Set(),
+  RECENT_BLOCKED_CAP: 4096,
+
+  init() {
+    if (!this._initPromise) {
+      this._initPromise = this._init().catch(e => {
+        this._initError = e;
+        lazy.log.error("init failed:", e);
+      });
+    }
+    return this._initPromise;
+  },
+
+  // Read a list's raw text. Like the RS client's #downloadAndStore, prefer the
+  // deterministic packaged dump resource; fall back to the RS attachment
+  // download (cache/dump fallbacks) only if that fails.
+  async _readListText(record) {
+    if (!record.attachment) {
+      return null;
+    }
+    try {
+      const url = `resource://app/defaults/settings/main/${COLLECTION_NAME}/${record.id}`;
+      const resp = await fetch(url);
+      if (resp.ok) {
+        const text = await resp.text();
+        if (text.length) {
+          return text;
+        }
+      }
+    } catch (e) {}
+    try {
+      const result = await lazy
+        .RemoteSettings(COLLECTION_NAME)
+        .attachments.download(record, {
+          fallbackToCache: true,
+          fallbackToDump: true,
+        });
+      return new TextDecoder().decode(new Uint8Array(result.buffer));
+    } catch (e) {
+      lazy.log.error(`failed to read list "${record.Name}":`, e);
+      return null;
+    }
+  },
+
+  async _init() {
+    if (!Services.prefs.getBoolPref(ENABLED_PREF, true)) {
+      lazy.log.info("disabled by pref");
+      return;
+    }
+
+    const t0 = Date.now();
+    const { StaticNetFilteringEngine } = ChromeUtils.importESModule(
+      "resource://gre/modules/UBOSnfe.sys.mjs"
+    );
+    const pslSelfie = ChromeUtils.importESModule(
+      "resource://gre/modules/UBOPslSelfie.sys.mjs"
+    ).default;
+    this._snfe = await StaticNetFilteringEngine.create({ pslSelfie });
+
+    const records = await lazy.RemoteSettings(COLLECTION_NAME).get();
+    const userText = this._userFilters();
+    const stamp = this._stamp(records, userText);
+    const selfiePath = PathUtils.join(PathUtils.profileDir, SELFIE_FILE);
+
+    let restored = false;
+    try {
+      const cached = await IOUtils.readJSON(selfiePath);
+      if (cached.stamp === stamp && typeof cached.selfie === "string") {
+        await this._snfe.deserialize(cached.selfie);
+        restored = true;
+        lazy.log.info(`engine restored from selfie (${Date.now() - t0}ms)`);
+      }
+    } catch (e) {
+      // No cache or stale cache: fall through to a full compile.
+    }
+
+    if (!restored) {
+      await this._compileEngine(records, userText, selfiePath, stamp, t0);
+    }
+
+    Services.obs.addObserver(this, "http-on-opening-request");
+    // Response-side hooks for $csp injection; cached/merged variants cover
+    // cache hits, which never fire the plain examine-response topic.
+    Services.obs.addObserver(this, "http-on-examine-response");
+    Services.obs.addObserver(this, "http-on-examine-cached-response");
+    Services.obs.addObserver(this, "http-on-examine-merged-response");
+    Services.obs.addObserver(this, "xpcom-shutdown");
+    // Recompile when the user edits their custom filters.
+    Services.prefs.addObserver(USER_FILTERS_PREF, this);
+    this._observing = true;
+    this._prefObserving = true;
+  },
+
+  _userFilters() {
+    return Services.prefs.getStringPref(USER_FILTERS_PREF, "").trim();
+  },
+
+  // Cheap non-cryptographic string hash (djb2) for cache-keying only.
+  _hashString(str) {
+    let h = 5381;
+    for (let i = 0; i < str.length; i++) {
+      h = (((h << 5) + h) ^ str.charCodeAt(i)) >>> 0;
+    }
+    return h.toString(16);
+  },
+
+  // Selfie key: the bundled dump uses a fixed last_modified for
+  // byte-reproducibility, so only the attachment hash changes when lists are
+  // refreshed. The user-filters hash is folded in so editing them invalidates
+  // a warm-start selfie compiled from the old filters.
+  _stamp(records, userText) {
+    const listStamp = records
+      .map(r => `${r.id}:${r.attachment?.hash || r.last_modified}`)
+      .sort()
+      .join("|");
+    return `${listStamp}|user:${this._hashString(userText)}`;
+  },
+
+  // Assemble base lists + user filters, (re)compile the engine, and refresh the
+  // selfie. useLists() resets and refills the singleton engine in place, so a
+  // request classified mid-rebuild may briefly miss; rebuilds are rare
+  // (startup cache-miss or a user filter edit) so that window is acceptable.
+  async _compileEngine(records, userText, selfiePath, stamp, t0) {
+    const lists = [];
+    for (const record of records) {
+      const raw = await this._readListText(record);
+      if (raw) {
+        lists.push({ name: record.Name, raw });
+      }
+    }
+    if (userText) {
+      lists.push({ name: USER_FILTERS_LIST_NAME, raw: userText });
+    }
+    if (!lists.length) {
+      lazy.log.warn("no filter lists available; engine stays empty");
+      return;
+    }
+    await this._snfe.useLists(lists);
+    lazy.log.info(
+      `engine compiled from ${lists.length} lists (${Date.now() - t0}ms)`
+    );
+    try {
+      const selfie = await this._snfe.serialize();
+      await IOUtils.writeJSON(selfiePath, { stamp, selfie });
+    } catch (e) {
+      lazy.log.warn("failed to write selfie cache:", e);
+    }
+  },
+
+  // Debounced entry point: rapid Saves from the filters page collapse into one
+  // rebuild.
+  _onUserFiltersChanged() {
+    if (this._rebuildTimer) {
+      lazy.clearTimeout(this._rebuildTimer);
+    }
+    this._rebuildTimer = lazy.setTimeout(() => {
+      this._rebuildTimer = null;
+      this._rebuildForUserFilters().catch(e =>
+        lazy.log.error("user-filter rebuild failed:", e)
+      );
+    }, REBUILD_DEBOUNCE_MS);
+  },
+
+  // Serialize rebuilds behind init and each other: the engine's useLists()
+  // throws if a compile is already pending.
+  _rebuildForUserFilters() {
+    const prev = this._rebuildQueue || this._initPromise || Promise.resolve();
+    this._rebuildQueue = prev.catch(() => {}).then(() => this._doRebuild());
+    return this._rebuildQueue;
+  },
+
+  async _doRebuild() {
+    if (!this._snfe) {
+      return;
+    }
+    const t0 = Date.now();
+    const records = await lazy.RemoteSettings(COLLECTION_NAME).get();
+    const userText = this._userFilters();
+    const stamp = this._stamp(records, userText);
+    const selfiePath = PathUtils.join(PathUtils.profileDir, SELFIE_FILE);
+    await this._compileEngine(records, userText, selfiePath, stamp, t0);
+    lazy.log.info("engine rebuilt after custom-filter change");
+  },
+
+  observe(subject, topic) {
+    switch (topic) {
+      case "http-on-opening-request":
+        this._onRequest(subject);
+        break;
+      case "http-on-examine-response":
+      case "http-on-examine-cached-response":
+      case "http-on-examine-merged-response":
+        this._onResponse(subject);
+        break;
+      case "nsPref:changed":
+        // Only USER_FILTERS_PREF is observed, so no need to check subject/data.
+        this._onUserFiltersChanged();
+        break;
+      case "xpcom-shutdown":
+        if (this._rebuildTimer) {
+          lazy.clearTimeout(this._rebuildTimer);
+          this._rebuildTimer = null;
+        }
+        if (this._prefObserving) {
+          Services.prefs.removeObserver(USER_FILTERS_PREF, this);
+          this._prefObserving = false;
+        }
+        if (this._observing) {
+          Services.obs.removeObserver(this, "http-on-opening-request");
+          Services.obs.removeObserver(this, "http-on-examine-response");
+          Services.obs.removeObserver(this, "http-on-examine-cached-response");
+          Services.obs.removeObserver(this, "http-on-examine-merged-response");
+          Services.obs.removeObserver(this, "xpcom-shutdown");
+          this._observing = false;
+        }
+        this._snfe = null;
+        break;
+    }
+  },
+
+  _onRequest(channel) {
+    if (!this._snfe || !(channel instanceof Ci.nsIHttpChannel)) {
+      return;
+    }
+    // Live kill switch: the Shields "Block ads" toggle flips this pref at
+    // runtime, so check it per-request rather than only at init.
+    if (!Services.prefs.getBoolPref(ENABLED_PREF, true)) {
+      return;
+    }
+    const uri = channel.URI;
+    if (!uri.schemeIs("http") && !uri.schemeIs("https")) {
+      return;
+    }
+    const loadInfo = channel.loadInfo;
+    const policyType = loadInfo.externalContentPolicyType;
+    // Never cancel top-level document loads; uBO only strict-blocks those
+    // behind an interstitial, which is out of scope here.
+    if (policyType === Ci.nsIContentPolicy.TYPE_DOCUMENT) {
+      return;
+    }
+    const loadingPrincipal = loadInfo.loadingPrincipal;
+    if (
+      !loadingPrincipal ||
+      !loadingPrincipal.isContentPrincipal ||
+      (!loadingPrincipal.schemeIs("http") &&
+        !loadingPrincipal.schemeIs("https"))
+    ) {
+      return;
+    }
+
+    let verdict;
+    try {
+      verdict = this._snfe.matchRequest({
+        url: uri.asciiSpec,
+        type: lazy.typeMap.get(policyType) || "other",
+        originURL: loadingPrincipal.originNoSuffix,
+      });
+    } catch (e) {
+      return;
+    }
+    if (verdict !== BLOCK) {
+      return;
+    }
+    if (this._shieldsDownFor(loadInfo)) {
+      return;
+    }
+
+    // toLogData() reads the engine's last-match registers, which the
+    // matchAndFetchModifiers call inside _maybeRedirect clobbers -- capture
+    // the blocking rule first.
+    let rule = "";
+    try {
+      rule = this._snfe.toLogData()?.raw || "";
+    } catch (e) {}
+
+    // $redirect: prefer serving uBO's neutered shim over a hard cancel so
+    // pages that depend on the resource's side effects don't break.
+    const type = lazy.typeMap.get(policyType) || "other";
+    const redirect = this._maybeRedirect(channel, uri, type, loadingPrincipal);
+    if (redirect) {
+      rule = redirect.rule || rule;
+    } else {
+      try {
+        channel.cancel(Cr.NS_ERROR_ABORT);
+      } catch (e) {
+        return;
+      }
+      this._recordBlocked(uri.asciiSpec);
+    }
+
+    let site = "";
+    try {
+      site = loadingPrincipal.baseDomain;
+    } catch (e) {}
+    if (site) {
+      this._blockedCounts.set(site, (this._blockedCounts.get(site) || 0) + 1);
+    }
+
+    // Feed the Shields Logger: subject is null, the JSON payload rides aData.
+    // Contract shared with neonwolf-shields-logger.js. list attribution needs
+    // uBO's reverse-lookup machinery and stays empty for now.
+    try {
+      const entry = {
+        time: Date.now(),
+        site,
+        url: uri.asciiSpec,
+        type,
+        action: redirect ? "redirected" : "blocked",
+        rule,
+        list: "",
+      };
+      if (redirect) {
+        entry.redirect = redirect.token;
+      }
+      Services.obs.notifyObservers(
+        null,
+        "neonwolf-blocked-request",
+        JSON.stringify(entry)
+      );
+    } catch (e) {}
+  },
+
+  // $redirect / $redirect-rule: resolve the highest-priority applicable
+  // neutered resource and serve it as a data: URI in place of the request.
+  // Simplified from uBO's redirectRequest: valueless exceptions disable all
+  // redirection for the request, valued ones that token; important-realm
+  // precedence is not re-implemented. A page CSP may still veto data: script
+  // loads -- the request was blocked either way, so that degrades to a plain
+  // block.
+  _maybeRedirect(channel, uri, type, loadingPrincipal) {
+    let directives;
+    try {
+      directives = this._snfe.matchAndFetchModifiers(
+        {
+          url: uri.asciiSpec,
+          type,
+          originURL: loadingPrincipal.originNoSuffix,
+        },
+        "redirect-rule"
+      );
+    } catch (e) {
+      return null;
+    }
+    if (!Array.isArray(directives) || !directives.length) {
+      return null;
+    }
+    const rr = lazy.redirectResources;
+    const excepted = new Set();
+    const candidates = [];
+    for (const directive of directives) {
+      const value = String(directive.value || "");
+      const sep = value.indexOf(":");
+      const token = sep === -1 ? value : value.slice(0, sep);
+      const priority =
+        sep === -1 ? 0 : parseInt(value.slice(sep + 1), 10) || 0;
+      if (directive.result === 2) {
+        if (!token) {
+          return null;
+        }
+        excepted.add(token);
+        continue;
+      }
+      candidates.push({ token, priority, directive });
+    }
+    let best = null;
+    for (const c of candidates) {
+      const token = rr.aliases[c.token] || c.token;
+      if (excepted.has(c.token) || excepted.has(token)) {
+        continue;
+      }
+      const resource = rr.resources[token];
+      if (!resource) {
+        continue;
+      }
+      if (!best || c.priority > best.priority) {
+        best = { token, priority: c.priority, directive: c.directive, resource };
+      }
+    }
+    if (!best) {
+      return null;
+    }
+    try {
+      const dataURI = `data:${best.resource.contentType};base64,${best.resource.base64}`;
+      channel.redirectTo(Services.io.newURI(dataURI));
+    } catch (e) {
+      // Too late to redirect this channel; caller falls back to cancel.
+      return null;
+    }
+    let rule = "";
+    try {
+      rule = best.directive.logData().raw || "";
+    } catch (e) {}
+    return { token: best.token, rule };
+  },
+
+  // $csp: inject Content-Security-Policy response headers on (sub)document
+  // loads. uBO semantics: a valueless exception cancels all csp injection for
+  // the request; a valued exception cancels that one directive.
+  _onResponse(channel) {
+    if (!this._snfe || !(channel instanceof Ci.nsIHttpChannel)) {
+      return;
+    }
+    if (!Services.prefs.getBoolPref(ENABLED_PREF, true)) {
+      return;
+    }
+    const uri = channel.URI;
+    if (!uri.schemeIs("http") && !uri.schemeIs("https")) {
+      return;
+    }
+    const loadInfo = channel.loadInfo;
+    const policyType = loadInfo.externalContentPolicyType;
+    const isDoc = policyType === Ci.nsIContentPolicy.TYPE_DOCUMENT;
+    if (!isDoc && policyType !== Ci.nsIContentPolicy.TYPE_SUBDOCUMENT) {
+      return;
+    }
+    // A top-level document is its own filtering context; a frame's context is
+    // the embedding document.
+    let originURL = uri.asciiSpec;
+    if (!isDoc) {
+      const loadingPrincipal = loadInfo.loadingPrincipal;
+      if (!loadingPrincipal || !loadingPrincipal.isContentPrincipal) {
+        return;
+      }
+      originURL = loadingPrincipal.originNoSuffix;
+    }
+    let directives;
+    try {
+      directives = this._snfe.matchAndFetchModifiers(
+        {
+          url: uri.asciiSpec,
+          type: isDoc ? "main_frame" : "sub_frame",
+          originURL,
+        },
+        "csp"
+      );
+    } catch (e) {
+      return;
+    }
+    if (!Array.isArray(directives) || !directives.length) {
+      return;
+    }
+    if (this._shieldsDownFor(loadInfo)) {
+      return;
+    }
+    const values = new Set();
