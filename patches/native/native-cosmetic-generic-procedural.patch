+NS_IMETHODIMP ContentClassifierService::GetGenericSelectors(
+    const nsACString& aUrl, const nsTArray<nsCString>& aClasses,
+    const nsTArray<nsCString>& aIds, nsTArray<nsCString>& aRetVal) {
+  aRetVal.Clear();
+
+  MutexAutoLock lock(mLock);
+  if (mInitPhase != InitPhase::InitSucceeded) {
+    return NS_OK;
+  }
+
+  nsTHashSet<nsCString> seen;
+  for (const auto& engine : mBlockEngines) {
+    nsTArray<nsCString> hideSelectors;
+    nsTArray<nsCString> proceduralActions;
+    nsTArray<nsCString> exceptions;
+    bool genericHide = false;
+    if (NS_FAILED(engine->GetCosmeticContext(aUrl, hideSelectors,
+                                             proceduralActions, exceptions,
+                                             genericHide))) {
+      continue;
+    }
+    // A $generichide exception for this url disables this engine's generic
+    // rules entirely.
+    if (genericHide) {
+      continue;
+    }
+
+    nsTArray<nsCString> generic;
+    if (NS_FAILED(engine->GetHiddenClassIdSelectors(aClasses, aIds, exceptions,
+                                                    generic))) {
+      continue;
+    }
+    for (auto& selector : generic) {
+      if (seen.EnsureInserted(selector)) {
+        aRetVal.AppendElement(selector);
+      }
+    }
+  }
+
+  MOZ_LOG_FMT(gContentClassifierLog, LogLevel::Debug,
+              "GetGenericSelectors - url={} classes={} ids={} count={}", aUrl,
+              aClasses.Length(), aIds.Length(), aRetVal.Length());
+  return NS_OK;
+}
+
