+
+// Neonwolf procedural cosmetic filtering: evaluates uBO-style procedural
+// cosmetic filters (has-text, matches-css, upward, xpath, ...) against the live
+// DOM and applies their action (hide/style/remove/...). The native part of each
+// filter is folded into a CSS prefix queried with querySelectorAll; the
+// remaining operators are evaluated in JS over the candidate set. Re-running is
+// cheap and idempotent so it can be driven by a MutationObserver.
+
+const HIDE_CLASS = "__nw-proc-hidden";
+
+// Split a `/pattern/flags` string into a precompiled matcher, otherwise treat
+// the argument as a literal substring.
+function compileMatcher(arg) {
+  if (typeof arg !== "string") {
+    return { literal: String(arg ?? "") };
+  }
+  if (arg.length > 1 && arg[0] === "/") {
+    const end = arg.lastIndexOf("/");
+    if (end > 0) {
+      try {
+        return { regex: new RegExp(arg.slice(1, end), arg.slice(end + 1)) };
+      } catch (e) {
+        // Fall through to literal handling on a malformed regex.
+      }
+    }
+  }
+  return { literal: arg };
+}
+
+function testMatcher(matcher, value) {
+  if (value == null) {
+    return false;
+  }
+  if (matcher.regex) {
+    return matcher.regex.test(value);
+  }
+  return value.includes(matcher.literal);
+}
+
+// A procedural operator is "native" (foldable into the CSS prefix) when it is a
+// plain css-selector, or a `has` whose argument is itself a plain selector that
+// FF152 can evaluate through native :has().
+function isNativeSelectorOp(op) {
+  return op.type === "css-selector" || op.type === "has";
+}
+
+// uBO procedural pseudo-class names (no leading ':' or trailing '('). Used to
+// find where the plain-CSS prefix of a raw selector string ends. Native :has()
+// is deliberately excluded so it stays folded in the CSS prefix.
+const PROC_OP_NAMES = new Set([
+  "has-text",
+  "-abp-has",
+  "upward",
+  "xpath",
+  "matches-css",
+  "matches-css-before",
+  "matches-css-after",
+  "matches-attr",
+  "matches-path",
+  "min-text-length",
+  "watch-attr",
+  "if",
+  "if-not",
+  "remove",
+  "style",
+]);
+
+// Map a uBO pseudo name to the internal JSON-op `type` understood by _compileOp.
+const RAW_OP_TYPES = {
+  "has-text": "has-text",
+  "-abp-has": "has",
+  if: "has",
+  "if-not": "has-not",
+  upward: "upward",
+  xpath: "xpath",
+  "matches-css": "matches-css",
+  "matches-css-before": "matches-css-before",
+  "matches-css-after": "matches-css-after",
+  "matches-attr": "matches-attr",
+  "min-text-length": "min-text-length",
+};
+
+// Return the index just past the ')' matching the '(' at `open`, respecting
+// nested parens and quoted strings.
+function skipParens(s, open) {
+  let depth = 0;
+  let quote = null;
+  for (let i = open; i < s.length; i++) {
+    const c = s[i];
+    if (quote) {
+      if (c === "\\") {
+        i++;
+      } else if (c === quote) {
+        quote = null;
+      }
+      continue;
+    }
+    if (c === '"' || c === "'") {
+      quote = c;
+    } else if (c === "(") {
+      depth++;
+    } else if (c === ")") {
+      depth--;
+      if (depth === 0) {
+        return i + 1;
+      }
+    }
+  }
+  return s.length;
+}
+
+// Return the index just past the ']' matching the '[' at `open`.
+function skipBrackets(s, open) {
+  let quote = null;
+  for (let i = open + 1; i < s.length; i++) {
+    const c = s[i];
+    if (quote) {
+      if (c === "\\") {
+        i++;
+      } else if (c === quote) {
+        quote = null;
+      }
+      continue;
+    }
+    if (c === '"' || c === "'") {
+      quote = c;
+    } else if (c === "]") {
+      return i + 1;
+    }
+  }
+  return s.length;
+}
+
+function isNameChar(c) {
+  return (
+    (c >= "a" && c <= "z") || (c >= "A" && c <= "Z") || c === "-"
+  );
+}
+
+export class ProceduralExecutor {
+  constructor(window, document) {
+    this._window = window;
+    this._document = document;
+    this._filters = [];
+    this._rafHandle = 0;
+    this._rawSeen = new Set();
+
+    // Idempotency tracking for the various actions.
+    this._styleApplied = new WeakMap();
+    this._removed = new WeakSet();
+    this._removeAttrDone = new WeakMap();
+    this._removeClassDone = new WeakMap();
+
+    try {
+      const css =
+        "data:text/css," +
+        encodeURIComponent(`.${HIDE_CLASS}{display:none!important}`);
+      window.windowUtils.loadSheetUsingURIString(
+        css,
+        window.windowUtils.AGENT_SHEET
+      );
+    } catch (e) {}
+  }
+
+  setFilters(jsonStrings) {
+    const filters = [];
+    for (const raw of jsonStrings || []) {
+      let parsed;
+      try {
+        parsed = JSON.parse(raw);
+      } catch (e) {
+        continue;
+      }
+      const compiled = this._compileFilter(parsed);
+      if (compiled) {
+        filters.push(compiled);
+      }
+    }
+    this._filters = filters;
+  }
+
+  // adblock-rust 0.12.1 surfaces procedural rules as raw uBO selector strings
+  // (e.g. `.box:has-text(Sponsored):upward(2)`) rather than as procedural JSON.
+  // Parse each into the same compiled form `apply()` consumes. Returns true if
+  // any new filter was added.
+  addRawSelectors(selStrings) {
+    let added = false;
+    for (const sel of selStrings || []) {
+      if (typeof sel !== "string" || !sel || this._rawSeen.has(sel)) {
+        continue;
+      }
+      this._rawSeen.add(sel);
+      const filter = this._compileRawSelector(sel);
+      if (filter) {
+        this._filters.push(filter);
+        added = true;
+      }
+    }
+    return added;
+  }
+
+  _compileRawSelector(sel) {
+    const parsed = this._parseRawSelector(sel);
+    if (!parsed) {
+      return null;
+    }
+    const tail = [];
+    const pathOps = [];
+    let action = { kind: "hide" };
+    for (const { name, arg } of parsed.ops) {
+      if (name === "matches-path") {
+        pathOps.push(compileMatcher(arg));
+      } else if (name === "remove") {
+        action = this._compileAction({ type: "remove" });
+      } else if (name === "style") {
+        action = this._compileAction({ type: "style", arg });
+      } else if (name === "watch-attr") {
+        // No-op as a filter; attribute mutations already re-drive apply().
+      } else {
+        const type = RAW_OP_TYPES[name];
+        const op = type ? this._compileOp({ type, arg }) : null;
+        if (op) {
+          tail.push(op);
+        }
+      }
+    }
+    return { prefix: parsed.prefix, tail, pathOps, action };
+  }
+
+  // Split a raw uBO selector into its leading plain-CSS prefix and the ordered
+  // list of procedural `{name, arg}` operators that follow it.
+  _parseRawSelector(sel) {
+    const n = sel.length;
+    let i = 0;
+    let prefixEnd = -1;
+    while (i < n) {
+      const c = sel[i];
+      if (c === "[") {
+        i = skipBrackets(sel, i);
+        continue;
+      }
+      if (c === ":") {
+        let j = i + 1;
+        while (j < n && isNameChar(sel[j])) {
+          j++;
+        }
+        const name = sel.slice(i + 1, j);
+        if (sel[j] === "(") {
+          if (PROC_OP_NAMES.has(name)) {
+            prefixEnd = i;
+            break;
+          }
+          i = skipParens(sel, j);
+          continue;
+        }
+        i = j;
+        continue;
+      }
+      i++;
+    }
+    if (prefixEnd === -1) {
+      return null;
+    }
+
+    const ops = [];
+    let k = prefixEnd;
+    while (k < n && sel[k] === ":") {
+      let j = k + 1;
+      while (j < n && isNameChar(sel[j])) {
+        j++;
+      }
+      const name = sel.slice(k + 1, j);
+      if (sel[j] !== "(") {
+        break;
+      }
+      const end = skipParens(sel, j);
+      ops.push({ name, arg: sel.slice(j + 1, end - 1).trim() });
+      k = end;
+      while (k < n && /\s/.test(sel[k])) {
+        k++;
+      }
+    }
+
+    return { prefix: sel.slice(0, prefixEnd).trim(), ops };
+  }
+
+  _compileFilter(parsed) {
+    const ops = parsed?.selector;
+    if (!Array.isArray(ops) || !ops.length) {
+      return null;
+    }
+
+    // Build the leading maximal run of native selector operators into a single
+    // CSS prefix; the rest become the JS-evaluated tail.
+    let prefix = "";
+    let i = 0;
+    for (; i < ops.length; i++) {
+      const op = ops[i];
+      if (op.type === "css-selector") {
+        prefix = prefix === "" ? op.arg : prefix + " " + op.arg;
+      } else if (op.type === "has" && prefix !== "") {
+        prefix += `:has(${op.arg})`;
+      } else {
+        break;
+      }
+    }
+
+    const tail = [];
+    const pathOps = [];
+    for (; i < ops.length; i++) {
+      const op = ops[i];
+      if (op.type === "matches-path") {
+        pathOps.push(compileMatcher(op.arg));
+        continue;
+      }
+      const compiled = this._compileOp(op);
+      if (compiled) {
+        tail.push(compiled);
+      }
+    }
+
+    return {
+      prefix,
+      tail,
+      pathOps,
+      action: this._compileAction(parsed.action),
+    };
+  }
+
+  _compileOp(op) {
+    switch (op.type) {
+      case "css-selector":
+      case "has":
+      case "has-not":
+      case "upward":
+      case "xpath":
+        return { type: op.type, arg: op.arg };
+      case "has-text":
+      case "min-text-length":
+        return { type: op.type, arg: op.arg, matcher: compileMatcher(op.arg) };
+      case "matches-attr": {
+        const eq = op.arg.indexOf("=");
+        if (eq === -1) {
+          return { type: op.type, name: compileMatcher(op.arg), value: null };
+        }
+        return {
+          type: op.type,
+          name: compileMatcher(op.arg.slice(0, eq)),
+          value: compileMatcher(op.arg.slice(eq + 1)),
+        };
+      }
+      case "matches-css":
+      case "matches-css-before":
+      case "matches-css-after": {
+        const colon = op.arg.indexOf(":");
+        const pseudo =
+          op.type === "matches-css-before"
+            ? "::before"
+            : op.type === "matches-css-after"
+              ? "::after"
+              : null;
+        if (colon === -1) {
+          return { type: "matches-css", prop: op.arg.trim(), pseudo, value: null };
+        }
+        return {
+          type: "matches-css",
+          prop: op.arg.slice(0, colon).trim(),
+          pseudo,
+          value: compileMatcher(op.arg.slice(colon + 1).trim()),
+        };
+      }
+      default:
+        return null;
+    }
+  }
+
+  _compileAction(action) {
+    if (!action || action.type === "style") {
+      const arg = action?.arg;
+      if (!action || arg == null) {
+        return { kind: "hide" };
+      }
+      const normalized = String(arg).replace(/\s+/g, "").toLowerCase();
+      if (normalized === "display:none!important" || normalized === "display:none") {
+        return { kind: "hide" };
+      }
+      return { kind: "style", cssText: arg };
+    }
+    switch (action.type) {
+      case "remove":
+        return { kind: "remove" };
+      case "remove-attr":
+        return { kind: "remove-attr", matcher: compileMatcher(action.arg) };
+      case "remove-class":
+        return { kind: "remove-class", matcher: compileMatcher(action.arg) };
+      default:
+        return { kind: "hide" };
+    }
+  }
+
+  markDirty() {
+    if (this._rafHandle) {
+      return;
+    }
+    try {
+      this._rafHandle = this._window.requestAnimationFrame(() => this.apply());
+    } catch (e) {
+      this._rafHandle = 0;
+    }
+  }
+
+  apply() {
+    if (this._rafHandle) {
+      try {
+        this._window.cancelAnimationFrame(this._rafHandle);
+      } catch (e) {}
+      this._rafHandle = 0;
+    }
+    if (!this._filters.length) {
+      return;
+    }
+    if (Cu.isDeadWrapper(this._window)) {
+      return;
+    }
+    for (const filter of this._filters) {
+      try {
+        this._applyFilter(filter);
+      } catch (e) {}
+    }
+  }
+
+  _applyFilter(filter) {
+    for (const matcher of filter.pathOps) {
+      if (!testMatcher(matcher, this._window.location.pathname)) {
+        return;
+      }
+    }
+
+    let candidates;
+    if (filter.prefix) {
+      candidates = Array.from(this._document.querySelectorAll(filter.prefix));
+    } else if (filter.tail.length) {
+      candidates = Array.from(this._document.querySelectorAll("*"));
+    } else {
+      return;
+    }
+
+    for (const op of filter.tail) {
+      candidates = this._applyOp(op, candidates);
+      if (!candidates.length) {
+        return;
+      }
+    }
+
+    for (const el of candidates) {
+      this._applyAction(filter.action, el);
+    }
+  }
+
+  _applyOp(op, candidates) {
+    switch (op.type) {
+      case "css-selector":
+        return candidates.filter(el => el.matches(op.arg));
+      case "has":
+        return candidates.filter(el => !!el.querySelector(op.arg));
+      case "has-not":
+        return candidates.filter(el => !el.querySelector(op.arg));
+      case "has-text":
+        return candidates.filter(el => testMatcher(op.matcher, el.textContent));
+      case "min-text-length": {
+        const min = parseInt(op.arg, 10) || 0;
+        return candidates.filter(el => el.textContent.length >= min);
+      }
+      case "matches-attr":
+        return candidates.filter(el => this._matchesAttr(op, el));
+      case "matches-css":
+        return candidates.filter(el => this._matchesCss(op, el));
+      case "upward":
+        return this._mapUpward(op, candidates);
+      case "xpath":
+        return this._mapXpath(op, candidates);
+      default:
+        return candidates;
+    }
+  }
+
+  _matchesAttr(op, el) {
+    if (op.name.regex) {
+      for (const attr of el.attributes) {
+        if (
+          op.name.regex.test(attr.name) &&
+          (op.value === null || testMatcher(op.value, attr.value))
+        ) {
+          return true;
+        }
+      }
+      return false;
+    }
+    const name = op.name.literal;
+    if (!el.hasAttribute(name)) {
+      return false;
+    }
+    return op.value === null || testMatcher(op.value, el.getAttribute(name));
+  }
+
+  _matchesCss(op, el) {
+    let style;
+    try {
+      style = this._window.getComputedStyle(el, op.pseudo);
+    } catch (e) {
+      return false;
+    }
+    if (!style) {
+      return false;
+    }
+    const value = style.getPropertyValue(op.prop) || style[op.prop];
+    if (op.value === null) {
+      return value != null && value !== "";
+    }
+    return testMatcher(op.value, value);
+  }
+
+  _mapUpward(op, candidates) {
+    const out = [];
+    const seen = new Set();
+    const n = /^\d+$/.test(String(op.arg).trim())
+      ? parseInt(op.arg, 10)
+      : null;
+    for (const el of candidates) {
+      let target = el;
+      if (n !== null) {
+        for (let k = 0; k < n && target; k++) {
+          target = target.parentElement;
+        }
+      } else {
+        target = el.closest(op.arg);
+      }
+      if (target && !seen.has(target)) {
+        seen.add(target);
+        out.push(target);
+      }
+    }
+    return out;
+  }
+
+  _mapXpath(op, candidates) {
+    const out = [];
+    const seen = new Set();
+    const XPathResult = this._window.XPathResult;
+    for (const el of candidates) {
+      let snapshot;
+      try {
+        snapshot = this._document.evaluate(
+          op.arg,
+          el,
+          null,
+          XPathResult.ORDERED_NODE_SNAPSHOT_TYPE,
+          null
+        );
+      } catch (e) {
+        continue;
+      }
+      for (let k = 0; k < snapshot.snapshotLength; k++) {
+        const node = snapshot.snapshotItem(k);
+        if (node && node.nodeType === 1 && !seen.has(node)) {
+          seen.add(node);
+          out.push(node);
+        }
+      }
+    }
+    return out;
+  }
+
+  _applyAction(action, el) {
+    switch (action.kind) {
+      case "hide":
+        if (!el.classList.contains(HIDE_CLASS)) {
+          el.classList.add(HIDE_CLASS);
+        }
+        break;
+      case "style":
+        if (this._styleApplied.get(el) !== action.cssText) {
+          el.style.cssText = action.cssText;
+          this._styleApplied.set(el, action.cssText);
+        }
+        break;
+      case "remove":
+        if (!this._removed.has(el)) {
+          this._removed.add(el);
+          el.remove();
+        }
+        break;
+      case "remove-attr":
+        this._applyRemoveAttr(action, el);
+        break;
+      case "remove-class":
+        this._applyRemoveClass(action, el);
+        break;
+    }
+  }
+
+  _applyRemoveAttr(action, el) {
+    let done = this._removeAttrDone.get(el);
+    const names = [];
+    if (action.matcher.regex) {
+      for (const attr of el.attributes) {
+        if (action.matcher.regex.test(attr.name)) {
+          names.push(attr.name);
+        }
+      }
+    } else {
+      names.push(action.matcher.literal);
+    }
+    for (const name of names) {
+      if (done && done.has(name)) {
+        continue;
+      }
+      if (el.hasAttribute(name)) {
+        el.removeAttribute(name);
+      }
+      if (!done) {
+        done = new Set();
+        this._removeAttrDone.set(el, done);
+      }
+      done.add(name);
+    }
+  }
+
+  _applyRemoveClass(action, el) {
+    let done = this._removeClassDone.get(el);
+    const names = [];
+    if (action.matcher.regex) {
+      for (const cls of el.classList) {
+        if (action.matcher.regex.test(cls)) {
+          names.push(cls);
+        }
+      }
+    } else {
+      names.push(action.matcher.literal);
+    }
+    for (const name of names) {
+      if (done && done.has(name)) {
+        continue;
+      }
+      el.classList.remove(name);
+      if (!done) {
+        done = new Set();
+        this._removeClassDone.set(el, done);
+      }
+      done.add(name);
+    }
+  }
+
+  destroy() {
+    if (this._rafHandle) {
+      try {
+        this._window.cancelAnimationFrame(this._rafHandle);
+      } catch (e) {}
+      this._rafHandle = 0;
+    }
+    this._filters = [];
+  }
+}
